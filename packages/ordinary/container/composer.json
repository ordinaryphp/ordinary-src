{
  "name": "ordinary/container",
  "description": "A modern PHP 8.5 dependency injection container with lazy loading, autowiring, and PSR-11 compliance",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "OrdinaryPHP Contributors"
    }
  ],
  "require": {
    "php": "^8.5",
    "psr/container": "^2.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^13.0"
  },
  "autoload": {
    "psr-4": {
      "Ordinary\\Container\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ordinary\\Container\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
