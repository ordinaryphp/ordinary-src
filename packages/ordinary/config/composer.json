{
  "name": "ordinary/config",
  "description": "Flat key/value configuration management with layered resolution for OrdinaryPHP",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "OrdinaryPHP Contributors"
    }
  ],
  "require": {
    "php": "^8.5"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^13.0"
  },
  "autoload": {
    "psr-4": {
      "Ordinary\\Config\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ordinary\\Config\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
